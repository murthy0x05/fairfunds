# Database Configuration
# You can use a local SQLite file for development, or a PostgreSQL connection string (e.g., from neon.tech)
DATABASE_URL="file:./dev.db"
# Example PostgreSQL URL: "postgresql://user:password@localhost:5432/fairfunds?schema=public"

# Authentication Secrets
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-this-to-a-random-secret-in-production"
AUTH_URL="http://localhost:3000"

# --- OAuth Credentials ---

# GitHub (Get from https://github.com/settings/developers)
AUTH_GITHUB_ID="your_github_client_id"
AUTH_GITHUB_SECRET="your_github_client_secret"

# Google (Get from https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID="your_google_client_id"
AUTH_GOOGLE_SECRET="your_google_client_secret"
